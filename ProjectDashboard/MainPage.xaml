<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ProjectDashboard.ViewModels"
             x:Class="ProjectDashboard.MainPage"
             x:DataType="vm:DashboardViewModel"
             Title="Project Dashboard">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="⚙ Settings"
                     Command="{Binding OpenSettingsCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
          Padding="24,16,24,24"
          RowSpacing="12">

        <!-- Token Tip Banner -->
        <Border Grid.Row="0"
                Background="{AppThemeBinding Light=#FFF8E1, Dark=#2C2500}"
                Stroke="{AppThemeBinding Light=#FFD54F, Dark=#5C4A00}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                IsVisible="{Binding IsTokenBannerVisible}"
                Padding="14,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                  ColumnSpacing="10">
                <Label Grid.Column="0"
                       Text="💡"
                       FontSize="15"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="Add a GitHub token in Settings to raise the API rate limit to 5,000 requests/hour and enable private repositories."
                       FontSize="12"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="Open Settings"
                        Command="{Binding OpenSettingsCommand}"
                        FontSize="11"
                        HeightRequest="30"
                        Padding="10,0"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#7B5800, Dark=#FFD54F}" />
                <Button Grid.Column="3"
                        Text="✕"
                        Command="{Binding DismissTokenBannerCommand}"
                        FontSize="12"
                        HeightRequest="30"
                        WidthRequest="30"
                        Padding="0"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#7B5800, Dark=#FFD54F}" />
            </Grid>
        </Border>

        <!-- Auth Error Banner -->
        <Border Grid.Row="1"
                Background="{AppThemeBinding Light=#FFEBEE, Dark=#2C0000}"
                Stroke="{AppThemeBinding Light=#EF9A9A, Dark=#5C0000}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                IsVisible="{Binding IsAuthErrorVisible}"
                Padding="14,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                  ColumnSpacing="10">
                <Label Grid.Column="0"
                       Text="⚠️"
                       FontSize="15"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="Your GitHub token is invalid or has expired. Please update it in Settings."
                       FontSize="12"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="Update Token"
                        Command="{Binding OpenSettingsCommand}"
                        FontSize="11"
                        HeightRequest="30"
                        Padding="10,0"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#B71C1C, Dark=#EF9A9A}" />
                <Button Grid.Column="3"
                        Text="✕"
                        Command="{Binding DismissAuthErrorCommand}"
                        FontSize="12"
                        HeightRequest="30"
                        WidthRequest="30"
                        Padding="0"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#B71C1C, Dark=#EF9A9A}" />
            </Grid>
        </Border>

        <!-- Add Project Row -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8">
            <Entry Grid.Column="0"
                   Placeholder="https://github.com/owner/repo"
                   Text="{Binding NewProjectUrl}"
                   ReturnCommand="{Binding AddProjectCommand}"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="Add Project"
                    Command="{Binding AddProjectCommand}" />
            <Button Grid.Column="2"
                    Text="⟳ Refresh All"
                    Command="{Binding RefreshAllCommand}" />
        </Grid>

        <!-- Status Row -->
        <Grid Grid.Row="3" HeightRequest="24">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#E53935"
                   FontSize="13"
                   IsVisible="{Binding HasError}"
                   VerticalOptions="Center" />
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="End"
                               VerticalOptions="Center"
                               HeightRequest="20"
                               WidthRequest="20" />
        </Grid>

        <!-- Projects Grid -->
        <CollectionView Grid.Row="4"
                        ItemsSource="{Binding Projects}">
            <CollectionView.EmptyView>
                <Label Text="No projects added yet. Paste a GitHub URL above and click Add Project."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Opacity="0.5"
                       FontSize="14" />
            </CollectionView.EmptyView>
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="3"
                                 HorizontalItemSpacing="12"
                                 VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ProjectCardViewModel">
                    <Border Stroke="{AppThemeBinding Light=#D8D8D8, Dark=#404040}"
                            StrokeThickness="1"
                            Background="{AppThemeBinding Light=White, Dark=#252525}"
                            StrokeShape="RoundRectangle 10"
                            Padding="0">
                        <Grid RowDefinitions="8,Auto,*,Auto">

                            <!-- Colored accent bar -->
                            <BoxView Grid.Row="0"
                                     Color="{Binding CardAccentColor}"
                                     VerticalOptions="Fill" />

                            <!-- Repo Name + Settings -->
                            <Grid Grid.Row="1"
                                  Margin="16,10,8,0"
                                  ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="⚙"
                                        Command="{Binding OpenSettingsCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{Binding CardAccentColor}"
                                        FontSize="16"
                                        HeightRequest="32"
                                        WidthRequest="32"
                                        Padding="0"
                                        VerticalOptions="Center" />
                            </Grid>

                            <!-- Issue Count Badge -->
                            <HorizontalStackLayout Grid.Row="2"
                                                   Margin="16,8,16,0"
                                                   Spacing="10"
                                                   VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 14"
                                        Stroke="Transparent"
                                        BackgroundColor="{Binding CardAccentColor}"
                                        Padding="12,6">
                                    <Label Text="{Binding OpenIssues}"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="22" />
                                </Border>
                                <Label Text="open issues"
                                       VerticalOptions="Center"
                                       FontSize="13"
                                       Opacity="0.75" />
                            </HorizontalStackLayout>

                            <!-- Footer: Last Updated + Remove -->
                            <Grid Grid.Row="3"
                                  Margin="16,8,16,12"
                                  ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding LastUpdatedText}"
                                       FontSize="11"
                                       Opacity="0.55"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="Remove"
                                        Command="{Binding DeleteCommand}"
                                        FontSize="11"
                                        HeightRequest="28"
                                        Padding="8,0"
                                        BackgroundColor="Transparent"
                                        TextColor="{Binding CardAccentColor}" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>

