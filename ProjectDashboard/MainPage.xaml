<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ProjectDashboard.ViewModels"
             x:Class="ProjectDashboard.MainPage"
             x:DataType="vm:DashboardViewModel"
             Title="Project Dashboard">

    <Grid RowDefinitions="Auto,Auto,*"
          Padding="24,16,24,24"
          RowSpacing="12">

        <!-- Add Project Row -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8">
            <Entry Grid.Column="0"
                   Placeholder="https://github.com/owner/repo"
                   Text="{Binding NewProjectUrl}"
                   ReturnCommand="{Binding AddProjectCommand}"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="Add Project"
                    Command="{Binding AddProjectCommand}" />
            <Button Grid.Column="2"
                    Text="⟳ Refresh All"
                    Command="{Binding RefreshAllCommand}" />
        </Grid>

        <!-- Status Row -->
        <Grid Grid.Row="1" HeightRequest="24">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#E53935"
                   FontSize="13"
                   IsVisible="{Binding HasError}"
                   VerticalOptions="Center" />
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="End"
                               VerticalOptions="Center"
                               HeightRequest="20"
                               WidthRequest="20" />
        </Grid>

        <!-- Projects Grid -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Projects}">
            <CollectionView.EmptyView>
                <Label Text="No projects added yet. Paste a GitHub URL above and click Add Project."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Opacity="0.5"
                       FontSize="14" />
            </CollectionView.EmptyView>
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="3"
                                 HorizontalItemSpacing="12"
                                 VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ProjectCardViewModel">
                    <Border Stroke="{AppThemeBinding Light=#D8D8D8, Dark=#404040}"
                            StrokeThickness="1"
                            Background="{AppThemeBinding Light=White, Dark=#252525}"
                            StrokeShape="RoundRectangle 10"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*,Auto"
                              Padding="16"
                              RowSpacing="10">

                            <!-- Repo Name -->
                            <Label Grid.Row="0"
                                   Text="{Binding DisplayName}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />

                            <!-- Issue Count Badge -->
                            <HorizontalStackLayout Grid.Row="1"
                                                   Spacing="10"
                                                   VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 14"
                                        Stroke="Transparent"
                                        Background="#E53935"
                                        Padding="12,6">
                                    <Label Text="{Binding OpenIssues}"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="22" />
                                </Border>
                                <Label Text="open issues"
                                       VerticalOptions="Center"
                                       FontSize="13"
                                       Opacity="0.75" />
                            </HorizontalStackLayout>

                            <!-- Footer: Last Updated + Remove -->
                            <Grid Grid.Row="2"
                                  ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding LastUpdatedText}"
                                       FontSize="11"
                                       Opacity="0.55"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="Remove"
                                        Command="{Binding DeleteCommand}"
                                        FontSize="11"
                                        HeightRequest="28"
                                        Padding="8,0"
                                        BackgroundColor="Transparent"
                                        TextColor="#E53935" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
