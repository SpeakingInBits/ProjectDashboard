<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ProjectDashboard.ViewModels"
             x:Class="ProjectDashboard.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="GitHub Settings">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Done" Clicked="OnDoneClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="32,24"
                             Spacing="16"
                             MaximumWidthRequest="580"
                             HorizontalOptions="Center">

            <Label Text="Personal Access Token"
                   FontSize="20"
                   FontAttributes="Bold" />

            <Label FontSize="13"
                   Opacity="0.75">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="A token raises the API rate limit from 60 to 5,000 requests/hour and allows access to private repositories. " />
                        <Span Text="Generate one at github.com/settings/tokens" TextColor="#4A90D9" />
                        <Span Text=" — grant the " />
                        <Span Text="repo" FontAttributes="Bold" />
                        <Span Text=" scope for private repos, or no scopes for public repos only." />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <!-- Token Entry Row -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0"
                       Placeholder="ghp_xxxxxxxxxxxxxxxxxxxx"
                       Text="{Binding Token}"
                       IsPassword="{Binding IsPasswordHidden}" />
                <Button Grid.Column="1"
                        Text="{Binding ShowToken, Converter={StaticResource BoolToShowHideConverter}}"
                        Command="{Binding ToggleShowTokenCommand}"
                        MinimumWidthRequest="70"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#555, Dark=#AAA}" />
            </Grid>

            <!-- Action Buttons -->
            <HorizontalStackLayout Spacing="8">
                <Button Text="Save Token"
                        Command="{Binding SaveCommand}"
                        MinimumWidthRequest="130" />
                <Button Text="Clear Token"
                        Command="{Binding ClearCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#E53935"
                        MinimumWidthRequest="130" />
            </HorizontalStackLayout>

            <!-- Status feedback -->
            <Label Text="{Binding StatusMessage}"
                   TextColor="#2ECC71"
                   FontSize="13"
                   IsVisible="{Binding IsStatusVisible}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
