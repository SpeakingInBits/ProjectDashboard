<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ProjectDashboard.ViewModels"
             x:Class="ProjectDashboard.Views.ProjectSettingsPage"
             x:DataType="vm:ProjectSettingsViewModel"
             Title="Project Settings"
             Shell.PresentationMode="ModalAnimated">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Cancel"
                     Command="{Binding CloseCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="24,20"
                             Spacing="24">

            <!-- Color Preview -->
            <Border StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    BackgroundColor="{Binding SelectedColor}"
                    HeightRequest="64"
                    HorizontalOptions="Fill">
                <Label Text="{Binding ProjectDisplayName}"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <!-- Section Header -->
            <Label Text="Choose a Color"
                   FontSize="14"
                   FontAttributes="Bold"
                   Opacity="0.6" />

            <!-- Color Swatches -->
            <FlexLayout BindableLayout.ItemsSource="{Binding ColorSwatches}"
                        Wrap="Wrap"
                        JustifyContent="Start"
                        AlignItems="Center">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:ColorSwatchViewModel">
                        <Grid WidthRequest="52"
                              HeightRequest="52"
                              Margin="4">
                            <Border StrokeShape="RoundRectangle 26"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding Color}"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                <Label Text="✓"
                                       TextColor="White"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding IsSelected}" />
                            </Border>
                            <!-- Selection ring -->
                            <Border StrokeShape="RoundRectangle 28"
                                    StrokeThickness="3"
                                    Stroke="{Binding Color}"
                                    BackgroundColor="Transparent"
                                    WidthRequest="52"
                                    HeightRequest="52"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    IsVisible="{Binding IsSelected}" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <!-- Randomize Button -->
            <Button Text="🎲  Randomize Color"
                    Command="{Binding RandomizeCommand}"
                    BackgroundColor="Transparent"
                    BorderColor="{AppThemeBinding Light=#D8D8D8, Dark=#404040}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light=#555555, Dark=#CCCCCC}"
                    CornerRadius="8"
                    HeightRequest="44"
                    FontSize="14" />

            <!-- Project Complete Toggle -->
            <Grid ColumnDefinitions="*,Auto"
                  Padding="4,0">
                <Label Grid.Column="0"
                       Text="Mark as Completed"
                       FontSize="15"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding IsCompleted}"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Save Button -->
            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{Binding SelectedColor}"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="48"
                    FontSize="15"
                    FontAttributes="Bold" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
